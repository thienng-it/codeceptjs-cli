{
  "name": "codeceptjs-cli",
  "description": "Next-generation production-grade CLI for the CodeceptJS testing framework",
  "version": "0.1.0",
  "author": "thienng-it",
  "bin": {
    "ccjs": "./bin/run.js"
  },
  "bugs": "https://github.com/thienng-it/codeceptjs-cli/issues",
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6",
    "@oclif/plugin-plugins": "^5",
    "chalk": "^5.4.1",
    "change-case": "^5.4.4",
    "cli-table3": "^0.6.5",
    "execa": "^9.5.2",
    "figures": "^6.1.0",
    "handlebars": "^4.7.8",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/compat": "^1",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/node": "^22",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "husky": "^9.1.7",
    "oclif": "^4",
    "prettier": "^3.4.2",
    "semantic-release": "^25.0.3",
    "shx": "^0.3.3",
    "ts-node": "^10",
    "tsup": "^8.5.1",
    "typescript": "^5",
    "vitepress": "^1.6.4",
    "vitest": "^2.1.8",
    "vue": "^3.5.29"
  },
  "peerDependencies": {
    "codeceptjs": "^3.6.0"
  },
  "peerDependenciesMeta": {
    "codeceptjs": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "homepage": "https://github.com/thienng-it/codeceptjs-cli",
  "keywords": [
    "codeceptjs",
    "testing",
    "e2e",
    "playwright",
    "cli",
    "test-automation",
    "oclif"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "ccjs",
    "dirname": "ccjs",
    "commands": "./dist/commands",
    "hooks": {
      "init": "./dist/hooks/init"
    },
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-plugins"
    ],
    "topicSeparator": " ",
    "topics": {
      "run": {
        "description": "Execute CodeceptJS tests"
      },
      "generate": {
        "description": "Scaffold test files, page objects, and helpers"
      }
    }
  },
  "repository": "thienng-it/codeceptjs-cli",
  "scripts": {
    "build": "tsup",
    "dev": "bin/dev.js",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "postpack": "shx rm -f oclif.manifest.json",
    "prepack": "oclif manifest && oclif readme",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "version": "oclif readme && git add README.md"
  },
  "types": "dist/index.d.ts"
}
